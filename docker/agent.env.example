# Inner Warden Agent - Environment Variables
# Copy to agent.env and fill in your values

# AI Provider (choose one)
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# Telegram notifications (optional)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF
# TELEGRAM_CHAT_ID=-100123456789

# Dashboard auth (recommended for production)
# INNERWARDEN_DASHBOARD_USER=admin
# INNERWARDEN_DASHBOARD_PASSWORD_HASH=$argon2id$v=19$m=19456,t=2,p=1$...

# Cloudflare (optional)
# CLOUDFLARE_API_TOKEN=...

# AbuseIPDB (optional)
# ABUSEIPDB_API_KEY=...
